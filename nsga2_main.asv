%% 封装: 只返回 [F1,F2]
function f = evacObjFun_wrapper(x, userData)
[vals, ~, ~] = evacObjFun(x, userData);
f = vals;
end

%% 构建候选路径库 (示例)
function allPaths = buildCandidatePaths(S, buildingNodes)
% 这里只示例：对(楼栋, 出口)存一条最短路
G = graph(S.AdjMatrix);
entranceNodes = find(string(S.Nodes.Type)=="Entrance");
B = length(buildingNodes);
E = length(entranceNodes);

allPaths = cell(B, E);
for b = 1:B
    startN = buildingNodes(b);
    for e = 1:E
        endN = entranceNodes(e);
        p = shortestpath(G, startN, endN);
        allPaths{b,e} = {p}; % 仅存1条
    end
end
end



function [f, g, h] = evacObjFun(x, userData)


S     = userData.S;
alpha = userData.alpha;
beta  = userData.beta;
vMax  = userData.vMax;
dt    = userData.timeStep;
maxT  = userData.maxSimulationTime;


x(x<0.01)=0.01;
X=ceil(x.*S.P);
alldis=S.alldis;
Y=S.YFenPei;
for i=1:length(X)
    alldis=alldis+S.dis(S.DFenPei{i}(1),S.DFenPei{i}(X(i)+1));
    Y(S.DFenPei{i}(X(i)+1))=Y(S.DFenPei{i}(X(i)+1))+12;
end

F1 = alldis;
F2 = var(Y);
%
f = [F1, F2];
g = [];
h = [];

end

% 单独画图
solID = find(Finall(:, 2) == min(Finall(:, 2))); % 找到疏散人数最均衡的解
xVec = xSolutions(solID, :);
xVec(xVec < 0.01) = 0.01;
X = ceil(xVec .* data.P);
data.dis = data.dis * 0.801449794;

figure;
for i = 1:length(data.road)
    temp = data.road{i};
    plot(temp(:, 1), temp(:, 2), 'k-'); hold on;
end

% 绘制已分配路径
for i = 1:size(data.FID, 1)
    a = [data.start(data.FID(i, 1), 1), data.binan(data.FID(i, 2), 1)];
    b = [data.start(data.FID(i, 1), 2), data.binan(data.FID(i, 2), 2)];
    plot(a, b, 'b-'); hold on;
    
    % 计算路径时间并显示
    path_length = data.dis(data.FID(i, 1), data.FID(i, 2)) * 0.0134432899; % 示例路径长度
    path_time = path_length / userData.vMax;
    text(mean(a), mean(b), sprintf('%.2f s', path_time), 'Color', 'b', 'FontSize', 8);
end 

% 绘制未分配路径
for i = 1:length(X)
    a = [data.start(data.DFenPei{i}(1), 1), data.binan(data.DFenPei{i}(X(i) + 1), 1)];
    b = [data.start(data.DFenPei{i}(1), 2), data.binan(data.DFenPei{i}(X(i) + 1), 2)];
    plot(a, b, 'b-'); hold on;
    
    % 计算路径时间并显示
    path_length = data.dis(data.DFenPei{i}(1), data.DFenPei{i}(X(i) + 1)) * 0.0134432899;
    path_time = path_length / userData.vMax;
    text(mean(a), mean(b), sprintf('%.2f s', path_time), 'Color', 'b', 'FontSize', 8);
end

h1 = scatter(data.binan(:, 1), data.binan(:, 2), 18, 'g^', 'filled'); % 画避难点
h2 = scatter(data.start(:, 1), data.start(:, 2), 8, 'ro', 'filled'); % 画宅基地
title('每个疏散点疏散人数最均衡（总拥挤度）方案');
legend([h1, h2], '避难点', '宅基地');
set(gca, 'FontName', 'Microsoft YaHei');
print(gcf, '-djpeg', '-r300', ['每个疏散点疏散人数最均衡（总拥挤度）方案.jpg']);








xlabel('X坐标');
ylabel('Y坐标');
title('疏散时间超过900秒的宅基地点分布');
grid on; % 添加网格
set(gca, 'FontName', 'Microsoft YaHei');

% 在每个点旁边添加编号
for i = 1:size(exceedCoords, 1)
    text(exceedCoords(i, 1), exceedCoords(i, 2), [' ' num2str(exceedIdx(i))], ...
         'Color', 'k', 'FontSize', 8, 'VerticalAlignment', 'bottom');
end

% 保存图像
print(gcf, '-djpeg', '-r300', ['疏散时间超过900秒的宅基地点分布.jpg']);





%超过900S的箱型图和柱状图
% 提取疏散时间超过900秒的编号和时间
thresholdTime = 900; % 设置时间阈值为900秒
exceedIdx = find(evacuationTimes > thresholdTime); % 找出疏散时间超过900秒的编号
exceedTimes = evacuationTimes(exceedIdx); % 提取这些编号对应的疏散时间

% 绘制柱状图
figure;
bar(exceedIdx, exceedTimes, 'FaceColor', 'b');
xlabel('宅基地点编号');
ylabel('疏散时间 (秒)');
title('疏散时间超过900秒的宅基地点');
set(gca, 'FontName', 'Microsoft YaHei');
grid on; % 添加网格
print(gcf, '-djpeg', '-r300', ['疏散时间超过900秒的宅基地点柱状图.jpg']);

% 绘制箱型图
figure;
boxplot(exceedTimes);
xlabel('宅基地点');
ylabel('疏散时间 (秒)');
title('疏散时间超过900秒的宅基地点箱型图');
set(gca, 'FontName', 'Microsoft YaHei');
grid on; % 添加网格
print(gcf, '-djpeg', '-r300', ['疏散时间超过900秒的宅基地点箱型图.jpg']);
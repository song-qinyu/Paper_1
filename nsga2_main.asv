load('sj5.mat');
alldis=0;
FID=[];
YFenPei=zeros(1,size(data.binan,1)); % 已有避难所的疏散人数
for i=1:size(data.start)
    if length(B{i})>1
%         DFenPei{length(DFenPei)+1}=[i,B{i}];
    else
        YFenPei(B{i})=YFenPei(B{i})+12;
        FID=[FID;i,B{i}];
        alldis=alldis+dis(i,B{i});
    end
end
data.FID=FID;
data.alldis=alldis;
P=[];
for i=1:length(DFenPei)
    P(i)=length(DFenPei{i})-1;
end
data.P=P;
data.dis=dis;
nVar = length(data.DFenPei);                   % 决策变量维度 = 2 * (楼栋数)

% ========== 3) 目标函数所需的其它参数 ==========
userData.S        = data;
userData.alpha    = 0.5;
userData.beta     = 0.5;
userData.vMax     = 1.2;
userData.timeStep = 1;
userData.maxSimulationTime = 600;

% 构建“候选路径库” (仅示例：默认只有1条最短路)
% 真实情况下你可以枚举更多可行路径


% ========== 4) 设置 gamultiobj (NSGA-II) 参数 ==========
popSize = 100;   % 种群大小
maxGen  = 100;   % 最大迭代代数

lb = zeros(1, nVar);
ub = ones(1,  nVar);

options = optimoptions('gamultiobj', ...
    'PopulationSize', popSize, ...
    'MaxGenerations', maxGen, ...
    'Display', 'iter', ...
    'PlotFcn', {@gaplotpareto}, ...
    'UseParallel', false, ...
    'UseVectorized', false);

% ========== 5) 调用 gamultiobj 进行多目标优化 ==========
problemFitness = @(x) evacObjFun_wrapper(x, userData);
[xSolutions, fSolutions, exitflag, output, population, score] = ...
    gamultiobj(problemFitness, nVar, [],[],[],[], lb, ub, [], options);

Finall=[];
for solID = 1:size(xSolutions,1)
    
    xVec = xSolutions(solID,:);
    
    xVec(xVec<0.01)=0.01;
    X=ceil(xVec.*data.P);
    alldis=data.alldis;
    Y=data.YFenPei;
    for i=1:length(X)
        alldis=alldis+data.dis(data.DFenPei{i}(1),data.DFenPei{i}(X(i)+1));
        Y(data.DFenPei{i}(X(i)+1))=Y(data.DFenPei{i}(X(i)+1))+1;
    end
 
    Finall=[Finall;fSolutions(solID,:)];
end

% ========== 6) 显示 & 可视化结果 ==========
disp('===== gamultiobj 运行结束 =====');
disp(output);

figure;

    homeIdx = data.FID(i, 1);
    path_length = data.dis(homeIdx, data.FID(i, 2))* 0.0134432899; % 路径长度
    evacuationTimes(homeIdx) = path_length / userData.vMax; % 路径时间
end

% 未分配路径的时间计算
for i = 1:length(X)
    homeIdx = data.DFenPei{i}(1);
    path_length = data.dis(homeIdx, data.DFenPei{i}(X(i) + 1))* 0.0134432899; % 路径长度
    evacuationTimes(homeIdx) = path_length / userData.vMax; % 路径时间
end

% 分组编号
groupSize = 50; % 每组50个编号
numGroups = ceil(numHomes / groupSize); % 计算分组数量
groupLabels = cell(1, numGroups); % 初始化分组标签
for i = 1:numGroups
    startIdx = (i - 1) * groupSize + 1;
    endIdx = min(i * groupSize, numHomes);
    groupLabels{i} = sprintf('%d-%d', startIdx, endIdx);
end

% 计算每个分组的平均疏散时间
groupTimes = zeros(numGroups, 1);
for i = 1:numGroups
    startIdx = (i - 1) * groupSize + 1;
    endIdx = min(i * groupSize, numHomes);
    groupTimes(i) = mean(evacuationTimes(startIdx:endIdx)); % 计算分组的平均疏散时间
end

% 绘制柱状图
figure;
bar(1:numGroups, groupTimes, 'FaceColor', 'b');
xlabel('宅基地点编号分组');
ylabel('平均疏散时间 (秒)');
